# Copy this file to .env.local in this folder, then replace placeholders.
# NextAuth: https://next-auth.js.org/configuration/options
# Local: http://localhost:3000  |  Vercel: https://your-project.vercel.app (exact production URL)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-string-for-example-openssl-rand-base64-32

# Admin demo login (Credentials provider) — no Google keys required
# Email: admin@volta.test  Password: demo123

# Google OAuth (NextAuth Google provider uses these names)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# MongoDB (mongoose + seed scripts). Use the SAME database name for Next and Python tools.
# Set MONGO_URI for all tools; MONGODB_URI is optional because Next.js also reads it if MONGO_URI is unset.
# MongoDB Compass: New Connection → paste this URI → connect → browse collections: products, purchases, users.
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce-597
# MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce-597

# UploadThing v7 (dashboard shows Secret and App ID)
UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=...
